\par {\pntext\pard\plain\s27 \fs20\cgrid \hich\af0\dbch\af0\loch\f0 126\tab}}\pard\plain \s27\qj\fi-567\li567\sa280\sl-280\slmult0\widctlpar\tx567\tx1134\tx1559\tx2126\tx2693{\*\pn \pnlvlbody\ilvl0\ls5\pnrnot0\pndec\pnfs20\pnstart1\pnindent360\pnhang}
\ls5\adjustright \fs26\lang2057\cgrid {\tab For these reasons, the questions reserved to the Full Court should be answered in the terms proposed by other members of the Court.
