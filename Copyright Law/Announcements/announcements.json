ile=\"{&quot;alternativeText&quot;:&quot;Copyright &amp; music - v5.pptx&quot;,&quot;linkName&quot;:&quot;Copyright &amp; music - v5.pptx&quot;,&quot;mimeType&quot;:&quot;application/vnd.openxmlformats-officedocument.presentationml.presentation&quot;,&quot;render&quot;:&quot;attachment&quot;,&quot;fileSize&quot;:27423420,&quot;resourceUrl&quot;:&quot;https://learn.uq.edu.au/bbcswebdav/internal/courses/LAWS5206_7620_20059/announcements/_953768_1/Copyright%20%26%20music%20-%20v5.pptx?Kq3cZcYS15=72501d55390d4d7f84a9c34f302e8821&VxJw3wfC56=1772365134&3cCnGYSz89=jg3qoEEouLcnenizLjjdKwLICe7UhyjfkAojVooooCE%3D&quot;}\">Copyright &amp; music - v5.pptx</a></p><p><a href=\"https://learn.uq.edu.au/bbcswebdav/internal/courses/LAWS5206_7620_20059/announcements/_953768_1/Flyer%20-%20The%20John%20McLaren%20Emmerson%20QC%20Essay%20Prize%202026.pdf?Kq3cZcYS15=72501d55390d4d7f84a9c34f302e8821&VxJw3wfC56=1772365134&3cCnGYSz89=pGZRPkzjuFPG3IYVHRK%2FDvS%2FHL4d64WVFj1fWFn7iKw%3D\" data-bbtype=\"attachment\" data-bbfile=\"{&quot;alternativeText&quot;:&quot;Flyer - The John McLaren Emmerson QC Essay Prize 2026.pdf&quot;,&quot;displayName&quot;:&quot;Flyer - The John McLaren Emmerson QC Essay Prize 2026.pdf&quot;,&quot;fileName&quot;:&quot;Flyer - The John McLaren Emmerson QC Essay Prize 2026.pdf&quot;,&quot;fileSize&quot;:130577,&quot;mimeType&quot;:&quot;application/pdf&quot;,&quot;render&quot;:&quot;attachment&quot;,&quot;resourceUrl&quot;:&quot;https://learn.uq.edu.au/bbcswebdav/internal/courses/LAWS5206_7620_20059/announcements/_953768_1/Flyer%20-%20The%20John%20McLaren%20Emmerson%20QC%20Essay%20Prize%202026.pdf?Kq3cZcYS15=72501d55390d4d7f84a9c34f302e8821&VxJw3wfC56=1772365134&3cCnGYSz89=pGZRPkzjuFPG3IYVHRK%2FDvS%2FHL4d64WVFj1fWFn7iKw%3D&quot;,&quot;linkName&quot;:&quot;Flyer - The John McLaren Emmerson QC Essay Prize 2026.pdf&quot;}\">Flyer - The John McLaren Emmerson QC Essay Prize 2026.pdf</a></p><br>",
